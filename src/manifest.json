{
  "manifest_version": 3,
  "name": "Douban Mastodon Sync",
  "version": "1.2",
  "description": "同步豆瓣广播到 Mastodon",
  "permissions": [
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "host_permissions": [
    "https://*.douban.com/*"
  ],
  "optional_host_permissions": [
    "https://*/*"
  ],
  "icons": {
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.douban.com/*",
        "https://m.douban.com/*",
        "https://douban.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js"],
      "matches": [
        "https://www.douban.com/*",
        "https://m.douban.com/*",
        "https://douban.com/*"
      ]
    }
  ]
}
